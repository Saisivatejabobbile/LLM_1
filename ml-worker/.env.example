# SLM Forge ML Worker — Environment Variables
# Copy this to .env and fill in your values

# ── Directories (Docker defaults shown) ──────────────────────────────────────
UPLOAD_DIR=/app/uploads
MODELS_DIR=/app/models
HF_HOME=/app/hf_cache

# ── llama.cpp (for GGUF export) ───────────────────────────────────────────────
# Path to your cloned llama.cpp repo
LLAMA_CPP_PATH=/app/llama.cpp

# ── Hugging Face ──────────────────────────────────────────────────────────────
# Required for gated models (Llama, Gemma) and HF Hub push
HF_TOKEN=hf_your_token_here

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list or * for all
# CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]

# ── Ollama ────────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434

# ── Training defaults (can be overridden per-request) ─────────────────────────
DEFAULT_MAX_SEQ_LENGTH=2048
DEFAULT_BATCH_SIZE=2
DEFAULT_EPOCHS=3
DEFAULT_LEARNING_RATE=0.0002
DEFAULT_LORA_RANK=16
DEFAULT_LORA_ALPHA=32
DEFAULT_LORA_DROPOUT=0.05

# ── Evaluation ────────────────────────────────────────────────────────────────
EVAL_TEST_SPLIT=0.2
EVAL_MAX_NEW_TOKENS=256
EVAL_MAX_SAMPLES=50

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
